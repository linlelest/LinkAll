<?xml version="1.0" encoding="utf-8"?>
<!--
    LinkALL Launcher 图标（自适应图标变体，仅 API 26+ 生效）
    说明：项目根目录 icon.jpeg 已复制到 drawable/icon.jpeg，
    AndroidManifest.xml 直接引用 @drawable/icon 使用该位图（全 API 通用）。
    本文件为 API 26+ 自适应图标变体，放在 drawable-v26/ 限定符目录下，
    避免在 minSdk=24 的工程中触发 <adaptive-icon> 链接错误。
    若需启用可改 manifest 引用为 @drawable/ic_launcher。
-->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/link_primary" />
    <foreground android:drawable="@drawable/icon" />
    <monochrome android:drawable="@drawable/icon" />
</adaptive-icon>
